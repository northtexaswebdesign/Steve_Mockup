  "sections": [
    {
      "type": "custom_html",
      "html": "<nav class=\"sticky top-0 z-50 w-full bg-white/90 backdrop-blur-md border-b border-slate-100 transition-all duration-300\">\n        <div class=\"max-w-7xl mx-auto px-6 lg:px-8 h-20 flex items-center justify-between\">\n            <!-- Brand -->\n            <a href=\"/\" class=\"flex items-center gap-2 group\">\n                <div class=\"w-8 h-8 bg-blue-600 rounded flex items-center justify-center text-white font-bold text-lg leading-none group-hover:bg-blue-700 transition-colors\">B</div>\n                <span class=\"font-semibold text-xl tracking-tight text-slate-900\">Bruneman<span class=\"text-slate-400 font-light\">Mediations</span></span>\n            </a>\n            \n            <!-- Links -->\n            <div class=\"hidden md:flex items-center space-x-8 text-sm font-medium text-slate-500\">\n                <a href=\"/\" class=\"hover:text-blue-600 transition-colors\">Home</a>\n                <a href=\"/services\" class=\"text-blue-600 font-semibold\">Mediation Services</a>\n                <a href=\"/#about\" class=\"hover:text-blue-600 transition-colors\">About Steve</a>\n                <a href=\"/#contact\" class=\"hover:text-blue-600 transition-colors\">Contact</a>\n            </div>\n\n            <!-- CTA -->\n            <div>\n                <a href=\"/#calendar\" class=\"inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-full shadow-lg shadow-blue-600/20 hover:shadow-blue-600/40 hover:-translate-y-0.5 transition-all duration-300\">\n                    Mediation Calendar\n                </a>\n            </div>\n        </div>\n    </nav>"
    },
    {
      "type": "custom_html",
      "html": "<header class=\"relative w-full min-h-[60vh] flex items-center bg-slate-50 overflow-hidden border-b border-slate-100\">\n        <!-- Background Image -->\n        <img src=\"https://picsum.photos/seed/minimalist-office-space/1920/1080\" alt=\"Minimalist office environment\" referrerpolicy=\"no-referrer\" class=\"absolute inset-0 w-full h-full object-cover object-center z-0 scale-105\">\n        \n        <!-- Gradient Overlay -->\n        <div class=\"absolute inset-0 bg-gradient-to-r from-white via-white/95 to-white/60 z-10\"></div>\n\n        <div class=\"relative z-20 max-w-7xl mx-auto px-6 lg:px-8 w-full py-20\">\n            <div class=\"grid grid-cols-12 gap-8\">\n                <div class=\"col-span-12 md:col-span-9 lg:col-span-7 flex flex-col justify-center\">\n                    <h2 class=\"text-sm font-bold text-blue-600 uppercase tracking-widest mb-4\">Our Expertise</h2>\n                    <h1 class=\"text-5xl md:text-6xl font-bold text-slate-900 tracking-tighter leading-[1.1] mb-6\">\n                        Structured paths to <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-blue-400\">peaceful resolution.</span>\n                    </h1>\n                    <p class=\"text-lg md:text-xl text-slate-600 font-light leading-relaxed mb-10 max-w-2xl\">\n                        We provide a neutral, focused environment designed to de-escalate conflict and facilitate practical agreements. Explore our tailored mediation formats below.\n                    </p>\n                </div>\n            </div>\n        </div>\n    </header>"
    },
    {
      "type": "custom_html",
      "html": "<main>\n        \n        <!-- Service 1: Full Day (Image Right) -->\n        <section class=\"py-32 bg-white overflow-hidden\">\n            <div class=\"max-w-7xl mx-auto px-6 lg:px-8\">\n                <div class=\"grid grid-cols-12 gap-16 lg:gap-24 items-center\">\n                    \n                    <!-- Content (7 cols) -->\n                    <div class=\"col-span-12 lg:col-span-7 order-2 lg:order-1\">\n                        <div class=\"w-14 h-14 rounded-full bg-blue-50 flex items-center justify-center mb-8 border border-blue-100\">\n                            <svg class=\"w-7 h-7 text-blue-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z\"></path></svg>\n                        </div>\n                        <h2 class=\"text-3xl md:text-4xl font-bold text-slate-900 tracking-tight mb-6\">Full-Day Mediation</h2>\n                        <p class=\"text-slate-600 leading-relaxed text-lg mb-6\">\n                            Our primary service format, designed for comprehensive resolution of multi-faceted family law disputes. A full-day session allows the necessary time to untangle complex financial portfolios, address high-conflict custody arrangements, and navigate intense emotional dynamics without the pressure of a ticking clock.\n                        </p>\n                        <ul class=\"space-y-4 mb-10\">\n                            <li class=\"flex items-start\">\n                                <svg class=\"w-6 h-6 text-blue-500 mr-3 shrink-0\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg>\n                                <span class=\"text-slate-700\">8 hours of dedicated, uninterrupted negotiation.</span>\n                            </li>\n                            <li class=\"flex items-start\">\n                                <svg class=\"w-6 h-6 text-blue-500 mr-3 shrink-0\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg>\n                                <span class=\"text-slate-700\">Ideal for high-asset property division and business valuations.</span>\n                            </li>\n                            <li class=\"flex items-start\">\n                                <svg class=\"w-6 h-6 text-blue-500 mr-3 shrink-0\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg>\n                                <span class=\"text-slate-700\">Deep-dive into sensitive child custody and visitation schedules.</span>\n                            </li>\n                        </ul>\n                        <a href=\"/#calendar\" class=\"inline-flex items-center justify-center px-8 py-3.5 text-sm font-medium text-slate-900 bg-white hover:bg-slate-50 border-2 border-slate-200 rounded-full transition-all duration-300 hover:border-blue-600 group\">\n                            Check Full-Day Availability\n                            <span class=\"ml-2 transform group-hover:translate-x-1 transition-transform text-blue-600\">→</span>\n                        </a>\n                    </div>\n\n                    <!-- Image (5 cols) -->\n                    <div class=\"col-span-12 lg:col-span-5 order-1 lg:order-2 relative\">\n                        <div class=\"absolute top-8 -right-8 w-full h-full bg-slate-50 rounded-3xl z-0 border border-slate-100\"></div>\n                        <div class=\"relative z-10 rounded-3xl overflow-hidden shadow-2xl shadow-slate-200/50\">\n                            <img src=\"https://picsum.photos/seed/conference-table/800/1000\" alt=\"Mediation conference room\" referrerpolicy=\"no-referrer\" class=\"w-full h-auto object-cover\">\n                        </div>\n                    </div>\n\n                </div>\n            </div>\n        </section>\n\n        <!-- Service 2: Half Day (Image Left) -->\n        <section class=\"py-32 bg-slate-50 border-y border-slate-100 overflow-hidden\">\n            <div class=\"max-w-7xl mx-auto px-6 lg:px-8\">\n                <div class=\"grid grid-cols-12 gap-16 lg:gap-24 items-center\">\n                    \n                    <!-- Image (5 cols) -->\n                    <div class=\"col-span-12 lg:col-span-5 relative\">\n                        <div class=\"absolute -top-8 -left-8 w-full h-full bg-blue-100/50 rounded-3xl z-0\"></div>\n                        <div class=\"relative z-10 rounded-3xl overflow-hidden shadow-2xl shadow-slate-200/50\">\n                            <img src=\"https://picsum.photos/seed/documents-signing/800/1000\" alt=\"Signing legal documents\" referrerpolicy=\"no-referrer\" class=\"w-full h-auto object-cover\">\n                        </div>\n                    </div>\n\n                    <!-- Content (7 cols) -->\n                    <div class=\"col-span-12 lg:col-span-7 lg:pl-10\">\n                        <div class=\"w-14 h-14 rounded-full bg-white flex items-center justify-center mb-8 shadow-sm border border-slate-100\">\n                            <svg class=\"w-7 h-7 text-blue-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg>\n                        </div>\n                        <h2 class=\"text-3xl md:text-4xl font-bold text-slate-900 tracking-tight mb-6\">Half-Day Mediation</h2>\n                        <p class=\"text-slate-600 leading-relaxed text-lg mb-6\">\n                            A highly focused, four-hour session built for efficiency. Half-day mediations are best suited for cases where the parties have already reached consensus on major issues but require a formal setting to finalize details, or for modifications involving a limited scope of disputes.\n                        </p>\n                        <ul class=\"space-y-4 mb-10\">\n                            <li class=\"flex items-start\">\n                                <svg class=\"w-6 h-6 text-blue-500 mr-3 shrink-0\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg>\n                                <span class=\"text-slate-700\">4 hours of concentrated negotiation (Morning or Afternoon).</span>\n                            </li>\n                            <li class=\"flex items-start\">\n                                <svg class=\"w-6 h-6 text-blue-500 mr-3 shrink-0\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg>\n                                <span class=\"text-slate-700\">Perfect for post-decree modifications or narrowed issues.</span>\n                            </li>\n                            <li class=\"flex items-start\">\n                                <svg class=\"w-6 h-6 text-blue-500 mr-3 shrink-0\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg>\n                                <span class=\"text-slate-700\">Cost-effective solution to avoid imminent trial dates.</span>\n                            </li>\n                        </ul>\n                        <a href=\"/#calendar\" class=\"inline-flex items-center justify-center px-8 py-3.5 text-sm font-medium text-slate-900 bg-white hover:bg-slate-50 border-2 border-slate-200 rounded-full transition-all duration-300 hover:border-blue-600 group\">\n                            Check Half-Day Availability\n                            <span class=\"ml-2 transform group-hover:translate-x-1 transition-transform text-blue-600\">→</span>\n                        </a>\n                    </div>\n\n                </div>\n            </div>\n        </section>\n\n        <!-- Specialized Expertise Section -->\n        <section class=\"py-32 bg-white\">\n            <div class=\"max-w-7xl mx-auto px-6 lg:px-8\">\n                <div class=\"text-center max-w-3xl mx-auto mb-20\">\n                    <h2 class=\"text-sm font-bold text-blue-600 uppercase tracking-widest mb-3\">Specialized Approach</h2>\n                    <h3 class=\"text-3xl md:text-4xl font-bold text-slate-900 tracking-tight mb-6\">\n                        Handling High-Conflict Dynamics\n                    </h3>\n                    <p class=\"text-slate-600 text-lg leading-relaxed\">\n                        With over 40 years of trial experience, Steve Bruneman brings a unique capability to de-escalate severely fractured relationships and complex psychological factors that derail standard negotiations.\n                    </p>\n                </div>\n\n                <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n                    <!-- Card 1 -->\n                    <div class=\"bg-slate-50 rounded-2xl p-8 border border-slate-100 hover:shadow-xl hover:shadow-slate-200/50 transition-all duration-300\">\n                        <div class=\"w-10 h-10 rounded-lg bg-white border border-slate-200 flex items-center justify-center mb-6\">\n                            <svg class=\"w-5 h-5 text-slate-700\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\"></path></svg>\n                        </div>\n                        <h4 class=\"text-lg font-bold text-slate-900 mb-3\">Mental Health &amp; Addiction</h4>\n                        <p class=\"text-slate-500 text-sm leading-relaxed\">\n                            Adept at structuring agreements that prioritize safety and stability when severe psychological issues, personality disorders, or substance abuse are central to the dispute.\n                        </p>\n                    </div>\n\n                    <!-- Card 2 -->\n                    <div class=\"bg-slate-50 rounded-2xl p-8 border border-slate-100 hover:shadow-xl hover:shadow-slate-200/50 transition-all duration-300\">\n                        <div class=\"w-10 h-10 rounded-lg bg-white border border-slate-200 flex items-center justify-center mb-6\">\n                            <svg class=\"w-5 h-5 text-slate-700\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg>\n                        </div>\n                        <h4 class=\"text-lg font-bold text-slate-900 mb-3\">High-Net-Worth Estates</h4>\n                        <p class=\"text-slate-500 text-sm leading-relaxed\">\n                            Experienced in deciphering complex financials, business ownership structures, executive compensation packages, and tracing hidden assets for equitable division.\n                        </p>\n                    </div>\n\n                    <!-- Card 3 -->\n                    <div class=\"bg-slate-50 rounded-2xl p-8 border border-slate-100 hover:shadow-xl hover:shadow-slate-200/50 transition-all duration-300\">\n                        <div class=\"w-10 h-10 rounded-lg bg-white border border-slate-200 flex items-center justify-center mb-6\">\n                            <svg class=\"w-5 h-5 text-slate-700\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z\"></path></svg>\n                        </div>\n                        <h4 class=\"text-lg font-bold text-slate-900 mb-3\">Severe Anger Dynamics</h4>\n                        <p class=\"text-slate-500 text-sm leading-relaxed\">\n                            Utilizing separate rooms (caucusing) and structured communication to ensure neither party feels intimidated, maintaining focus on logic rather than reactive emotion.\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- The Process (Minimal Stepper) -->\n        <section class=\"py-24 bg-slate-900 text-white\">\n            <div class=\"max-w-7xl mx-auto px-6 lg:px-8\">\n                <div class=\"text-center mb-16\">\n                    <h2 class=\"text-sm font-bold text-blue-400 uppercase tracking-widest mb-3\">How It Works</h2>\n                    <h3 class=\"text-3xl md:text-4xl font-bold tracking-tight\">The Path to Agreement</h3>\n                </div>\n\n                <div class=\"grid grid-cols-1 md:grid-cols-3 gap-12 relative\">\n                    <!-- Connecting Line (Desktop) -->\n                    <div class=\"hidden md:block absolute top-6 left-1/6 right-1/6 h-0.5 bg-slate-800 z-0\"></div>\n\n                    <!-- Step 1 -->\n                    <div class=\"relative z-10 text-center\">\n                        <div class=\"w-12 h-12 mx-auto bg-blue-600 rounded-full flex items-center justify-center font-bold text-lg mb-6 shadow-lg shadow-blue-600/20\">1</div>\n                        <h4 class=\"text-xl font-semibold mb-3\">Secure Your Date</h4>\n                        <p class=\"text-slate-400 text-sm leading-relaxed max-w-xs mx-auto\">\n                            Use our online calendar to reserve a half-day or full-day session. An immediate confirmation secures your time.\n                        </p>\n                    </div>\n\n                    <!-- Step 2 -->\n                    <div class=\"relative z-10 text-center\">\n                        <div class=\"w-12 h-12 mx-auto bg-slate-800 border-2 border-slate-700 rounded-full flex items-center justify-center font-bold text-lg mb-6\">2</div>\n                        <h4 class=\"text-xl font-semibold mb-3\">Pre-Mediation Briefing</h4>\n                        <p class=\"text-slate-400 text-sm leading-relaxed max-w-xs mx-auto\">\n                            Attorneys submit confidential memorandums outlining the core issues, allowing Steve to prepare a tailored strategy.\n                        </p>\n                    </div>\n\n                    <!-- Step 3 -->\n                    <div class=\"relative z-10 text-center\">\n                        <div class=\"w-12 h-12 mx-auto bg-slate-800 border-2 border-slate-700 rounded-full flex items-center justify-center font-bold text-lg mb-6\">3</div>\n                        <h4 class=\"text-xl font-semibold mb-3\">The Mediation Session</h4>\n                        <p class=\"text-slate-400 text-sm leading-relaxed max-w-xs mx-auto\">\n                            Parties meet in our secure facilities (or virtually). Steve shuttles between rooms to forge a binding settlement agreement.\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- Final CTA -->\n        <section class=\"py-32 bg-white text-center\">\n            <div class=\"max-w-3xl mx-auto px-6\">\n                <h2 class=\"text-4xl md:text-5xl font-bold text-slate-900 tracking-tight mb-6\">Ready to resolve your case?</h2>\n                <p class=\"text-xl text-slate-600 mb-10 font-light\">\n                    Avoid the financial and emotional toll of a trial. View Steve's real-time availability and lock in your mediation date today.\n                </p>\n                <a href=\"/#calendar\" class=\"inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-full shadow-xl shadow-blue-600/20 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300\">\n                    View Scheduling Calendar\n                    <svg class=\"w-4 h-4 ml-2\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14 5l7 7m0 0l-7 7m7-7H3\"></path></svg>\n                </a>\n            </div>\n        </section>\n\n    </main>"
    },
    {
      "type": "custom_html",
      "html": "<footer class=\"bg-slate-900 text-slate-300 py-20 border-t border-slate-800\">\n        <div class=\"max-w-7xl mx-auto px-6 lg:px-8\">\n            <div class=\"grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-8\">\n                \n                <!-- Brand & Address (4 cols) -->\n                <div class=\"col-span-12 md:col-span-4 lg:col-span-4\">\n                    <div class=\"flex items-center gap-2 mb-6 text-white\">\n                        <div class=\"w-8 h-8 bg-blue-600 rounded flex items-center justify-center font-bold text-lg leading-none\">B</div>\n                        <span class=\"font-semibold text-xl tracking-tight\">Bruneman Mediations</span>\n                    </div>\n                    <p class=\"text-sm leading-relaxed mb-6 text-slate-400\">\n                        Campbell Centre, Tower II<br>\n                        8150 N. Central Expwy., 10th Floor<br>\n                        Dallas, Texas 75206\n                    </p>\n                    <a href=\"#\" class=\"inline-flex items-center text-sm font-medium text-blue-400 hover:text-blue-300 transition-colors\">\n                        Map &amp; Directions <svg class=\"w-4 h-4 ml-1\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14\"></path></svg>\n                    </a>\n                </div>\n\n                <!-- Contact (4 cols) -->\n                <div class=\"col-span-12 md:col-span-4 lg:col-span-4\">\n                    <h4 class=\"text-white font-semibold mb-6 uppercase tracking-wider text-sm\">Contact Us</h4>\n                    <ul class=\"space-y-4 text-sm\">\n                        <li class=\"flex items-start\">\n                            <span class=\"text-slate-500 w-16\">Phone:</span>\n                            <a href=\"tel:2147444440\" class=\"hover:text-white transition-colors\">214-744-4440</a>\n                        </li>\n                        <li class=\"flex items-start\">\n                            <span class=\"text-slate-500 w-16\">Fax:</span>\n                            <span>214-744-4441</span>\n                        </li>\n                    </ul>\n                </div>\n\n                <!-- Links & Payment (4 cols) -->\n                <div class=\"col-span-12 md:col-span-4 lg:col-span-4\">\n                    <h4 class=\"text-white font-semibold mb-6 uppercase tracking-wider text-sm\">Quick Links</h4>\n                    <ul class=\"space-y-3 text-sm mb-8\">\n                        <li><a href=\"#\" class=\"hover:text-white transition-colors\">Make a Payment</a></li>\n                        <li><a href=\"/#about\" class=\"hover:text-white transition-colors\">About Steve</a></li>\n                        <li><a href=\"/#calendar\" class=\"hover:text-white transition-colors\">Mediation Calendar</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition-colors\">Disclaimer &amp; Privacy Policy</a></li>\n                    </ul>\n                </div>\n\n            </div>\n            \n            <div class=\"mt-20 pt-8 border-t border-slate-800 text-xs text-slate-500 flex flex-col sm:flex-row justify-between items-center\">\n                <p>© 2026 Bruneman Mediations. All rights reserved.</p>\n                <p class=\"mt-2 sm:mt-0 text-slate-600 italic\">Wireframe UI mockup. Typography: Inter (Sans-Serif).</p>\n            </div>\n        </div>\n    </footer>"
    }
  ]
}