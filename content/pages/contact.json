  "sections": [
    {
      "type": "custom_html",
      "html": "<nav class=\"sticky top-0 z-50 w-full bg-white/90 backdrop-blur-md border-b border-slate-100 transition-all duration-300\">\n        <div class=\"max-w-7xl mx-auto px-6 lg:px-8 h-20 flex items-center justify-between\">\n            <!-- Brand -->\n            <a href=\"/\" class=\"flex items-center gap-2 group\">\n                <div class=\"w-8 h-8 bg-blue-600 rounded flex items-center justify-center text-white font-bold text-lg leading-none group-hover:bg-blue-700 transition-colors\">B</div>\n                <span class=\"font-semibold text-xl tracking-tight text-slate-900\">Bruneman<span class=\"text-slate-400 font-light\">Mediations</span></span>\n            </a>\n            \n            <!-- Links -->\n            <div class=\"hidden md:flex items-center space-x-8 text-sm font-medium\">\n                <a href=\"/\" class=\"text-slate-500 hover:text-blue-600 transition-colors\">Home</a>\n                <a href=\"/#about\" class=\"text-slate-500 hover:text-blue-600 transition-colors\">About Steve</a>\n                <a href=\"/#services\" class=\"text-slate-500 hover:text-blue-600 transition-colors\">Mediation Services</a>\n                <a href=\"/contact\" class=\"text-blue-600 transition-colors\">Contact</a>\n            </div>\n\n            <!-- CTA -->\n            <div>\n                <a href=\"/#calendar\" class=\"inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-full shadow-lg shadow-blue-600/20 hover:shadow-blue-600/40 hover:-translate-y-0.5 transition-all duration-300\">\n                    Mediation Calendar\n                </a>\n            </div>\n        </div>\n    </nav>"
    },
    {
      "type": "custom_html",
      "html": "<header class=\"relative w-full min-h-[50vh] flex items-center bg-slate-50 overflow-hidden\">\n        <!-- Background Image -->\n        <img src=\"https://picsum.photos/seed/dallas-architecture-light/1920/1080\" alt=\"Dallas office architecture\" referrerpolicy=\"no-referrer\" class=\"absolute inset-0 w-full h-full object-cover object-center z-0 scale-105 opacity-60\">\n        \n        <!-- Gradient Overlay -->\n        <div class=\"absolute inset-0 bg-gradient-to-r from-white via-white/95 to-white/70 z-10\"></div>\n\n        <div class=\"relative z-20 max-w-7xl mx-auto px-6 lg:px-8 w-full py-20\">\n            <div class=\"grid grid-cols-12 gap-8\">\n                <div class=\"col-span-12 md:col-span-8 lg:col-span-6 flex flex-col justify-center\">\n                    <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 text-blue-700 text-xs font-semibold tracking-wide uppercase mb-6 w-max border border-blue-100\">\n                        Dallas, Texas Office\n                    </div>\n                    <h1 class=\"text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 tracking-tighter leading-[1.1] mb-6\">\n                        Let's begin the <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-blue-400\">conversation.</span>\n                    </h1>\n                    <p class=\"text-lg text-slate-600 font-light leading-relaxed max-w-xl\">\n                        Whether you are ready to secure a mediation date or need to discuss the specifics of an upcoming case, our office is here to facilitate a smooth process.\n                    </p>\n                </div>\n            </div>\n        </div>\n    </header>"
    },
    {
      "type": "custom_html",
      "html": "<main class=\"flex-grow py-24 bg-white relative\">\n        <div class=\"max-w-7xl mx-auto px-6 lg:px-8\">\n            <div class=\"grid grid-cols-12 gap-16 lg:gap-24\">\n                \n                <!-- Left: Contact Information (5 cols) -->\n                <div class=\"col-span-12 lg:col-span-5 flex flex-col justify-between\">\n                    <div>\n                        <h2 class=\"text-sm font-bold text-blue-600 uppercase tracking-widest mb-3\">Get in Touch</h2>\n                        <h3 class=\"text-3xl font-bold text-slate-900 tracking-tight mb-8\">\n                            Direct communication for legal professionals and individuals.\n                        </h3>\n                        <p class=\"text-slate-600 leading-relaxed mb-12\">\n                            Our team responds promptly to all inquiries during standard business hours. For immediate scheduling needs, please utilize our online mediation calendar.\n                        </p>\n\n                        <!-- Info Blocks -->\n                        <div class=\"space-y-8\">\n                            <!-- Location -->\n                            <div class=\"flex items-start gap-4 group\">\n                                <div class=\"w-12 h-12 rounded-full bg-slate-50 flex items-center justify-center shrink-0 border border-slate-100 group-hover:border-blue-200 group-hover:bg-blue-50 transition-colors\">\n                                    <svg class=\"w-5 h-5 text-slate-600 group-hover:text-blue-600 transition-colors\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z\"></path><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M15 11a3 3 0 11-6 0 3 3 0 016 0z\"></path></svg>\n                                </div>\n                                <div>\n                                    <h4 class=\"text-sm font-bold text-slate-900 mb-1\">Office Location</h4>\n                                    <p class=\"text-slate-600 text-sm leading-relaxed\">\n                                        Campbell Centre, Tower II<br>\n                                        8150 N. Central Expwy., 10th Floor<br>\n                                        Dallas, Texas 75206\n                                    </p>\n                                    <a href=\"#\" class=\"inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-700 mt-2\">\n                                        Get Directions →\n                                    </a>\n                                </div>\n                            </div>\n\n                            <!-- Phone/Fax -->\n                            <div class=\"flex items-start gap-4 group\">\n                                <div class=\"w-12 h-12 rounded-full bg-slate-50 flex items-center justify-center shrink-0 border border-slate-100 group-hover:border-blue-200 group-hover:bg-blue-50 transition-colors\">\n                                    <svg class=\"w-5 h-5 text-slate-600 group-hover:text-blue-600 transition-colors\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z\"></path></svg>\n                                </div>\n                                <div>\n                                    <h4 class=\"text-sm font-bold text-slate-900 mb-1\">Phone &amp; Fax</h4>\n                                    <p class=\"text-slate-600 text-sm leading-relaxed\">\n                                        Main: <a href=\"tel:2147444440\" class=\"hover:text-blue-600 transition-colors\">214-744-4440</a><br>\n                                        Fax: 214-744-4441\n                                    </p>\n                                </div>\n                            </div>\n                            \n                            <!-- Email -->\n                            <div class=\"flex items-start gap-4 group\">\n                                <div class=\"w-12 h-12 rounded-full bg-slate-50 flex items-center justify-center shrink-0 border border-slate-100 group-hover:border-blue-200 group-hover:bg-blue-50 transition-colors\">\n                                    <svg class=\"w-5 h-5 text-slate-600 group-hover:text-blue-600 transition-colors\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z\"></path></svg>\n                                </div>\n                                <div>\n                                    <h4 class=\"text-sm font-bold text-slate-900 mb-1\">Email inquiries</h4>\n                                    <p class=\"text-slate-600 text-sm leading-relaxed\">\n                                        <a href=\"mailto:admin@brunemanmediations.com\" class=\"hover:text-blue-600 transition-colors\">admin@brunemanmediations.com</a>\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- Subtle separator and hours -->\n                    <div class=\"mt-12 pt-8 border-t border-slate-100\">\n                        <h4 class=\"text-xs font-bold text-slate-400 uppercase tracking-wider mb-3\">Office Hours</h4>\n                        <div class=\"flex justify-between text-sm text-slate-600 max-w-xs mb-2\">\n                            <span>Monday – Friday</span>\n                            <span class=\"font-medium text-slate-900\">8:30 AM – 5:30 PM</span>\n                        </div>\n                        <div class=\"flex justify-between text-sm text-slate-600 max-w-xs\">\n                            <span>Saturday – Sunday</span>\n                            <span class=\"font-medium text-slate-400\">Closed</span>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Right: Contact Form (7 cols) -->\n                <div class=\"col-span-12 lg:col-span-7 relative\">\n                    <!-- Decorative background element for depth -->\n                    <div class=\"absolute -inset-4 bg-slate-50 rounded-[2.5rem] -z-10 transform -rotate-1\"></div>\n\n                    <div class=\"bg-white p-8 sm:p-12 rounded-3xl border border-slate-100 shadow-2xl shadow-slate-200/50\">\n                        <form action=\"#\" method=\"POST\" class=\"space-y-6\">\n                            \n                            <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-6\">\n                                <!-- First Name -->\n                                <div class=\"space-y-2\">\n                                    <label for=\"first-name\" class=\"block text-sm font-medium text-slate-700\">First Name</label>\n                                    <input type=\"text\" id=\"first-name\" name=\"first-name\" class=\"w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-400 transition-all text-slate-800 placeholder-slate-400\" placeholder=\"Jane\" required=\"\">\n                                </div>\n                                <!-- Last Name -->\n                                <div class=\"space-y-2\">\n                                    <label for=\"last-name\" class=\"block text-sm font-medium text-slate-700\">Last Name</label>\n                                    <input type=\"text\" id=\"last-name\" name=\"last-name\" class=\"w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-400 transition-all text-slate-800 placeholder-slate-400\" placeholder=\"Doe\" required=\"\">\n                                </div>\n                            </div>\n\n                            <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-6\">\n                                <!-- Email Address -->\n                                <div class=\"space-y-2\">\n                                    <label for=\"email\" class=\"block text-sm font-medium text-slate-700\">Email Address</label>\n                                    <input type=\"email\" id=\"email\" name=\"email\" class=\"w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-400 transition-all text-slate-800 placeholder-slate-400\" placeholder=\"jane@example.com\" required=\"\">\n                                </div>\n                                <!-- Phone Number -->\n                                <div class=\"space-y-2\">\n                                    <label for=\"phone\" class=\"block text-sm font-medium text-slate-700\">Phone Number <span class=\"text-slate-400 font-normal\">(Optional)</span></label>\n                                    <input type=\"tel\" id=\"phone\" name=\"phone\" class=\"w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-400 transition-all text-slate-800 placeholder-slate-400\" placeholder=\"(555) 000-0000\">\n                                </div>\n                            </div>\n\n                            <!-- Inquiry Type -->\n                            <div class=\"space-y-2\">\n                                <label for=\"inquiry-type\" class=\"block text-sm font-medium text-slate-700\">Nature of Inquiry</label>\n                                <div class=\"relative\">\n                                    <select id=\"inquiry-type\" name=\"inquiry-type\" class=\"w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-400 transition-all text-slate-800 appearance-none cursor-pointer\">\n                                        <option value=\"scheduling\">Mediation Scheduling</option>\n                                        <option value=\"general\">General Question</option>\n                                        <option value=\"billing\">Billing Inquiry</option>\n                                        <option value=\"other\">Other</option>\n                                    </select>\n                                    <div class=\"pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-500\">\n                                        <svg class=\"h-4 w-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"></path></svg>\n                                    </div>\n                                </div>\n                            </div>\n\n                            <!-- Message -->\n                            <div class=\"space-y-2\">\n                                <label for=\"message\" class=\"block text-sm font-medium text-slate-700\">Message</label>\n                                <textarea id=\"message\" name=\"message\" rows=\"4\" class=\"w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-4 focus:ring-blue-600/10 focus:border-blue-400 transition-all text-slate-800 placeholder-slate-400 resize-none\" placeholder=\"How can we assist you?\"></textarea>\n                            </div>\n\n                            <!-- Disclaimer -->\n                            <div class=\"flex items-start gap-3 bg-blue-50/50 p-4 rounded-xl border border-blue-100\">\n                                <svg class=\"w-5 h-5 text-blue-600 shrink-0 mt-0.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg>\n                                <p class=\"text-xs text-slate-600 leading-relaxed\">\n                                    <strong class=\"font-semibold text-slate-800\">Confidentiality Notice:</strong> Please do not include confidential or sensitive case details in this form. Submitting this form does not establish an attorney-client or mediator-client relationship.\n                                </p>\n                            </div>\n\n                            <!-- Submit -->\n                            <div class=\"pt-2\">\n                                <button type=\"submit\" class=\"w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 text-sm font-medium text-white bg-slate-900 hover:bg-black rounded-full shadow-xl shadow-slate-900/20 hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-300\">\n                                    Send Message\n                                    <svg class=\"w-4 h-4 ml-2\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14 5l7 7m0 0l-7 7m7-7H3\"></path></svg>\n                                </button>\n                            </div>\n                        </form>\n                    </div>\n                </div>\n\n            </div>\n        </div>\n    </main>"
    },
    {
      "type": "custom_html",
      "html": "<footer class=\"bg-slate-900 text-slate-300 py-20 border-t border-slate-800 mt-auto\">\n        <div class=\"max-w-7xl mx-auto px-6 lg:px-8\">\n            <div class=\"grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-8\">\n                \n                <!-- Brand & Address (4 cols) -->\n                <div class=\"col-span-12 md:col-span-4 lg:col-span-4\">\n                    <div class=\"flex items-center gap-2 mb-6 text-white\">\n                        <div class=\"w-8 h-8 bg-blue-600 rounded flex items-center justify-center font-bold text-lg leading-none\">B</div>\n                        <span class=\"font-semibold text-xl tracking-tight\">Bruneman Mediations</span>\n                    </div>\n                    <p class=\"text-sm leading-relaxed mb-6 text-slate-400\">\n                        Campbell Centre, Tower II<br>\n                        8150 N. Central Expwy., 10th Floor<br>\n                        Dallas, Texas 75206\n                    </p>\n                    <a href=\"#\" class=\"inline-flex items-center text-sm font-medium text-blue-400 hover:text-blue-300 transition-colors\">\n                        Map &amp; Directions <svg class=\"w-4 h-4 ml-1\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14\"></path></svg>\n                    </a>\n                </div>\n\n                <!-- Contact (4 cols) -->\n                <div class=\"col-span-12 md:col-span-4 lg:col-span-4\">\n                    <h4 class=\"text-white font-semibold mb-6 uppercase tracking-wider text-sm\">Contact Us</h4>\n                    <ul class=\"space-y-4 text-sm\">\n                        <li class=\"flex items-start\">\n                            <span class=\"text-slate-500 w-16\">Phone:</span>\n                            <a href=\"tel:2147444440\" class=\"hover:text-white transition-colors\">214-744-4440</a>\n                        </li>\n                        <li class=\"flex items-start\">\n                            <span class=\"text-slate-500 w-16\">Fax:</span>\n                            <span>214-744-4441</span>\n                        </li>\n                    </ul>\n                </div>\n\n                <!-- Links & Payment (4 cols) -->\n                <div class=\"col-span-12 md:col-span-4 lg:col-span-4\">\n                    <h4 class=\"text-white font-semibold mb-6 uppercase tracking-wider text-sm\">Quick Links</h4>\n                    <ul class=\"space-y-3 text-sm mb-8\">\n                        <li><a href=\"#\" class=\"hover:text-white transition-colors\">Make a Payment</a></li>\n                        <li><a href=\"/#about\" class=\"hover:text-white transition-colors\">About Steve</a></li>\n                        <li><a href=\"/#calendar\" class=\"hover:text-white transition-colors\">Mediation Calendar</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition-colors\">Disclaimer &amp; Privacy Policy</a></li>\n                    </ul>\n                </div>\n\n            </div>\n            \n            <div class=\"mt-20 pt-8 border-t border-slate-800 text-xs text-slate-500 flex flex-col sm:flex-row justify-between items-center\">\n                <p>© 2026 Bruneman Mediations. All rights reserved.</p>\n                <p class=\"mt-2 sm:mt-0 text-slate-600 italic\">Wireframe UI mockup. Typography: Inter (Sans-Serif).</p>\n            </div>\n        </div>\n    </footer>"
    }
  ]
}