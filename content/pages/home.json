    {
      "type": "custom_html",
      "html": "<nav class=\"sticky top-0 z-50 w-full bg-white/90 backdrop-blur-md border-b border-slate-100 transition-all duration-300\">\n        <div class=\"max-w-7xl mx-auto px-6 lg:px-8 h-20 flex items-center justify-between\">\n            <!-- Brand -->\n            <div class=\"flex items-center gap-2\">\n                <div class=\"w-8 h-8 bg-blue-600 rounded flex items-center justify-center text-white font-bold text-lg leading-none\">B</div>\n                <span class=\"font-semibold text-xl tracking-tight text-slate-900\">Bruneman<span class=\"text-slate-400 font-light\">Mediations</span></span>\n            </div>\n            \n            <!-- Links (Hidden on mobile for wireframe simplicity, flex on md) -->\n            <div class=\"hidden md:flex items-center space-x-8 text-sm font-medium text-slate-500\">\n                <a href=\"#about\" class=\"hover:text-blue-600 transition-colors\">About Steve</a>\n                <a href=\"#services\" class=\"hover:text-blue-600 transition-colors\">Mediation Services</a>\n                <a href=\"#contact\" class=\"hover:text-blue-600 transition-colors\">Contact</a>\n            </div>\n\n            <!-- CTA -->\n            <div>\n                <a href=\"#calendar\" class=\"inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-full shadow-lg shadow-blue-600/20 hover:shadow-blue-600/40 hover:-translate-y-0.5 transition-all duration-300\">\n                    Mediation Calendar\n                </a>\n            </div>\n        </div>\n    </nav>"
    },
    {
      "type": "custom_html",
      "html": "<header class=\"relative w-full min-h-[85vh] flex items-center bg-slate-50 overflow-hidden\">\n        <!-- Background Image with Specific Seed -->\n        <img src=\"https://picsum.photos/seed/minimalist-architecture/1920/1080\" alt=\"Serene architectural background\" referrerpolicy=\"no-referrer\" class=\"absolute inset-0 w-full h-full object-cover object-center z-0 scale-105\">\n        \n        <!-- Gradient Overlay for Ultra-Minimalist Bright Mode -->\n        <div class=\"absolute inset-0 bg-gradient-to-r from-white via-white/90 to-white/40 z-10\"></div>\n\n        <div class=\"relative z-20 max-w-7xl mx-auto px-6 lg:px-8 w-full py-20\">\n            <div class=\"grid grid-cols-12 gap-8\">\n                <!-- Text Content taking up 7 columns for balanced asymmetry -->\n                <div class=\"col-span-12 md:col-span-9 lg:col-span-7 flex flex-col justify-center\">\n                    \n                    <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 text-blue-700 text-xs font-semibold tracking-wide uppercase mb-8 w-max border border-blue-100\">\n                        <span class=\"w-2 h-2 rounded-full bg-blue-600 animate-pulse\"></span>\n                        Accepting New Cases\n                    </div>\n\n                    <h1 class=\"text-5xl md:text-6xl lg:text-7xl font-bold text-slate-900 tracking-tighter leading-[1.1] mb-6\">\n                        Finding common ground in <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-blue-400\">complex disputes.</span>\n                    </h1>\n                    \n                    <p class=\"text-lg md:text-xl text-slate-600 font-light leading-relaxed mb-10 max-w-2xl\">\n                        Expert family law mediation by Steve Bruneman, AV Preeminent rated attorney with over 40 years of trial and settlement experience in Dallas, Texas. We turn contention into resolution.\n                    </p>\n                    \n                    <div class=\"flex flex-col sm:flex-row items-start gap-4\">\n                        <a href=\"#calendar\" class=\"inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white bg-slate-900 hover:bg-black rounded-full shadow-xl shadow-slate-900/20 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300\">\n                            Reserve a Date\n                            <svg class=\"w-4 h-4 ml-2\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14 5l7 7m0 0l-7 7m7-7H3\"></path></svg>\n                        </a>\n                        <a href=\"#about\" class=\"inline-flex items-center justify-center px-8 py-4 text-base font-medium text-slate-700 bg-white hover:bg-slate-50 border border-slate-200 rounded-full transition-all duration-300\">\n                            Meet Steve Bruneman\n                        </a>\n                    </div>\n                </div>\n            </div>\n        </div>\n        \n        <!-- Scroll indicator -->\n        <div class=\"absolute bottom-10 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center animate-bounce text-slate-400\">\n            <span class=\"text-xs uppercase tracking-widest mb-2 font-medium\">Scroll</span>\n            <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 14l-7 7m0 0l-7-7m7 7V3\"></path></svg>\n        </div>\n    </header>"
    },
    {
      "type": "custom_html",
      "html": "<section id=\"services\" class=\"py-32 bg-white relative\">\n        <div class=\"max-w-7xl mx-auto px-6 lg:px-8\">\n            <!-- Grid 12 - Split 5/7 -->\n            <div class=\"grid grid-cols-12 gap-16 lg:gap-24 items-center\">\n                \n                <!-- Left Text (5 cols) -->\n                <div class=\"col-span-12 lg:col-span-5\">\n                    <h2 class=\"text-sm font-bold text-blue-600 uppercase tracking-widest mb-3\">Mediation Services</h2>\n                    <h3 class=\"text-3xl md:text-4xl font-bold text-slate-900 tracking-tight mb-6 leading-tight\">\n                        Structured environments for constructive dialogue.\n                    </h3>\n                    <p class=\"text-slate-600 leading-relaxed mb-8\">\n                        Whether dealing with complex property division, challenging child custody arrangements, or severe emotional dynamics, our mediation formats are designed to foster productive negotiations and avoid the cost and stress of trial.\n                    </p>\n                    <a href=\"#calendar\" class=\"inline-flex items-center text-blue-600 font-semibold hover:text-blue-700 group transition-colors\">\n                        View Scheduling Calendar \n                        <span class=\"ml-2 transform group-hover:translate-x-1 transition-transform\">→</span>\n                    </a>\n                </div>\n\n                <!-- Right Cards (7 cols) -->\n                <div class=\"col-span-12 lg:col-span-7\">\n                    <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-6 relative\">\n                        <!-- Decorative background element -->\n                        <div class=\"absolute -inset-4 bg-slate-50 rounded-3xl -z-10 transform rotate-1\"></div>\n\n                        <!-- Card 1 -->\n                        <div class=\"bg-white p-8 rounded-2xl border border-slate-100 shadow-xl shadow-slate-200/40 hover:-translate-y-2 hover:shadow-2xl hover:shadow-blue-900/5 transition-all duration-300 flex flex-col h-full\">\n                            <div class=\"w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center mb-6\">\n                                <svg class=\"w-6 h-6 text-blue-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg>\n                            </div>\n                            <h4 class=\"text-xl font-bold text-slate-900 mb-3\">Half-Day Mediation</h4>\n                            <p class=\"text-slate-500 text-sm leading-relaxed mb-8 flex-grow\">\n                                Ideal for cases with limited issues in dispute or for parties who are close to a settlement but need a neutral environment to finalize terms. \n                            </p>\n                            <div class=\"pt-4 border-t border-slate-100 mt-auto\">\n                                <span class=\"text-sm font-medium text-slate-900\">4 Hours Dedicated Time</span>\n                            </div>\n                        </div>\n\n                        <!-- Card 2 -->\n                        <div class=\"bg-white p-8 rounded-2xl border border-slate-100 shadow-xl shadow-slate-200/40 hover:-translate-y-2 hover:shadow-2xl hover:shadow-blue-900/5 transition-all duration-300 flex flex-col h-full lg:mt-12\">\n                            <div class=\"w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center mb-6\">\n                                <svg class=\"w-6 h-6 text-blue-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z\"></path></svg>\n                            </div>\n                            <h4 class=\"text-xl font-bold text-slate-900 mb-3\">Full-Day Mediation</h4>\n                            <p class=\"text-slate-500 text-sm leading-relaxed mb-8 flex-grow\">\n                                Comprehensive mediation designed for complex property disputes, high-conflict custody matters, and cases involving substantial psychological dynamics.\n                            </p>\n                            <div class=\"pt-4 border-t border-slate-100 mt-auto\">\n                                <span class=\"text-sm font-medium text-slate-900\">8 Hours Dedicated Time</span>\n                            </div>\n                        </div>\n\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>"
    },
    {
      "type": "custom_html",
      "html": "<section id=\"about\" class=\"py-32 bg-slate-50 overflow-hidden\">\n        <div class=\"max-w-7xl mx-auto px-6 lg:px-8\">\n            <div class=\"grid grid-cols-12 gap-16 items-center\">\n                \n                <!-- Left Image Composition (5 cols) -->\n                <div class=\"col-span-12 lg:col-span-5 relative\">\n                    <!-- Offset background block for depth -->\n                    <div class=\"absolute -top-8 -left-8 w-full h-full bg-blue-100 rounded-3xl z-0\"></div>\n                    \n                    <div class=\"relative z-10 rounded-3xl overflow-hidden shadow-2xl shadow-slate-300/50 group\">\n                        <!-- High quality portrait placeholder -->\n                        <img src=\"https://picsum.photos/seed/executive-portrait/800/1000\" alt=\"Steve Bruneman\" referrerpolicy=\"no-referrer\" class=\"w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-700 ease-in-out\">\n                        \n                        <!-- Overlay badge -->\n                        <div class=\"absolute bottom-6 right-6 bg-white/90 backdrop-blur-sm p-4 rounded-xl shadow-lg\">\n                            <p class=\"text-xs font-bold text-slate-400 uppercase tracking-wider mb-1\">Author Of</p>\n                            <p class=\"text-sm font-semibold text-slate-900 italic\">\"Winning the Marriage Gamble\"</p>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Right Content (7 cols) -->\n                <div class=\"col-span-12 lg:col-span-7 lg:pl-10\">\n                    <h2 class=\"text-sm font-bold text-blue-600 uppercase tracking-widest mb-3\">About Steve Bruneman</h2>\n                    <h3 class=\"text-3xl md:text-5xl font-bold text-slate-900 tracking-tight mb-8 leading-tight\">\n                        Decades of trial experience. <br>A profound focus on resolution.\n                    </h3>\n                    \n                    <div class=\"space-y-6 text-slate-600 leading-relaxed text-lg\">\n                        <p>\n                            Steve Bruneman is an AV Preeminent rated, board-certified family law attorney with an exceptional career spanning over four decades. As a trial lawyer since 1982 and a seven-time Texas SuperLawyer, Steve has handled every conceivable family law issue.\n                        </p>\n                        <p>\n                            Having tried countless cases before courts and juries, he intimately understands the immense financial and emotional toll of litigation. This deep understanding of the psychological dynamics—especially concerning mental illness and severe anger issues—makes him exceptionally effective at managing parties' emotions during mediation.\n                        </p>\n                    </div>\n\n                    <!-- Credibility Grid -->\n                    <div class=\"grid grid-cols-2 gap-6 mt-10 pt-10 border-t border-slate-200\">\n                        <div>\n                            <span class=\"block text-3xl font-bold text-slate-900 mb-1\">40+</span>\n                            <span class=\"text-sm font-medium text-slate-500\">Years Practicing Law</span>\n                        </div>\n                        <div>\n                            <span class=\"block text-3xl font-bold text-slate-900 mb-1\">7x</span>\n                            <span class=\"text-sm font-medium text-slate-500\">Texas SuperLawyer</span>\n                        </div>\n                        <div>\n                            <span class=\"block text-3xl font-bold text-slate-900 mb-1\">AV</span>\n                            <span class=\"text-sm font-medium text-slate-500\">Preeminent Rated</span>\n                        </div>\n                        <div>\n                            <span class=\"block text-3xl font-bold text-slate-900 mb-1\">2000</span>\n                            <span class=\"text-sm font-medium text-slate-500\">Board Certified</span>\n                        </div>\n                    </div>\n\n                </div>\n            </div>\n        </div>\n    </section>"
    },
    {
      "type": "custom_html",
      "html": "<section id=\"calendar\" class=\"py-32 bg-white\">\n        <div class=\"max-w-7xl mx-auto px-6 lg:px-8\">\n            \n            <!-- Section Header -->\n            <div class=\"text-center max-w-2xl mx-auto mb-16\">\n                <h2 class=\"text-sm font-bold text-blue-600 uppercase tracking-widest mb-3\">Availability</h2>\n                <h3 class=\"text-3xl md:text-4xl font-bold text-slate-900 tracking-tight mb-4\">\n                    Secure Your Mediation Date\n                </h3>\n                <p class=\"text-slate-600\">\n                    Choose an available date below for either a full-day or half-day mediation. You and Steve will receive an immediate confirmation email, followed by detailed instructions from our office.\n                </p>\n            </div>\n\n            <!-- Calendar Wireframe Interface -->\n            <div class=\"max-w-5xl mx-auto bg-white rounded-3xl shadow-2xl shadow-slate-200/50 border border-slate-100 overflow-hidden\">\n                \n                <!-- Calendar Toolbar -->\n                <div class=\"px-8 py-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50\">\n                    <h4 class=\"text-xl font-semibold text-slate-900\">November 2024</h4>\n                    <div class=\"flex gap-2\">\n                        <button class=\"p-2 rounded-full hover:bg-slate-200 text-slate-500 transition-colors\">\n                            <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 19l-7-7 7-7\"></path></svg>\n                        </button>\n                        <button class=\"p-2 rounded-full hover:bg-slate-200 text-slate-500 transition-colors\">\n                            <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"></path></svg>\n                        </button>\n                    </div>\n                </div>\n\n                <!-- Calendar Grid -->\n                <div class=\"p-8\">\n                    <!-- Days Header -->\n                    <div class=\"grid grid-cols-7 gap-4 mb-4 text-center\">\n                        <div class=\"text-xs font-semibold text-slate-400 uppercase tracking-wider\">Sun</div>\n                        <div class=\"text-xs font-semibold text-slate-400 uppercase tracking-wider\">Mon</div>\n                        <div class=\"text-xs font-semibold text-slate-400 uppercase tracking-wider\">Tue</div>\n                        <div class=\"text-xs font-semibold text-slate-400 uppercase tracking-wider\">Wed</div>\n                        <div class=\"text-xs font-semibold text-slate-400 uppercase tracking-wider\">Thu</div>\n                        <div class=\"text-xs font-semibold text-slate-400 uppercase tracking-wider\">Fri</div>\n                        <div class=\"text-xs font-semibold text-slate-400 uppercase tracking-wider\">Sat</div>\n                    </div>\n\n                    <!-- Days Grid (Dummy Data) -->\n                    <div class=\"grid grid-cols-7 gap-4\">\n                        <!-- Empty slots -->\n                        <div class=\"aspect-square rounded-xl bg-transparent\"></div>\n                        <div class=\"aspect-square rounded-xl bg-transparent\"></div>\n                        \n                        <!-- Past Date -->\n                        <div class=\"aspect-square rounded-xl bg-slate-50 border border-slate-100 flex flex-col justify-center items-center opacity-50 cursor-not-allowed\">\n                            <span class=\"text-lg text-slate-400\">1</span>\n                        </div>\n                        \n                        <!-- Booked Date -->\n                        <div class=\"aspect-square rounded-xl bg-red-50 border border-red-100 flex flex-col justify-center items-center opacity-70 cursor-not-allowed relative\">\n                            <span class=\"text-lg text-slate-600 line-through\">2</span>\n                            <span class=\"absolute bottom-2 text-[10px] font-semibold text-red-500 uppercase\">Booked</span>\n                        </div>\n\n                        <!-- Available Date (Interactive) -->\n                        <button class=\"aspect-square rounded-xl bg-white border-2 border-slate-100 hover:border-blue-600 hover:shadow-lg hover:shadow-blue-100 flex flex-col justify-center items-center group transition-all duration-200 relative focus:outline-none focus:ring-4 focus:ring-blue-100\">\n                            <span class=\"text-lg font-semibold text-slate-900 group-hover:text-blue-600 transition-colors\">3</span>\n                            <span class=\"absolute bottom-2 text-[10px] font-bold text-green-500 uppercase bg-green-50 px-2 py-0.5 rounded-full group-hover:bg-blue-50 group-hover:text-blue-600 transition-colors\">Available</span>\n                        </button>\n\n                        <button class=\"aspect-square rounded-xl bg-white border-2 border-slate-100 hover:border-blue-600 hover:shadow-lg hover:shadow-blue-100 flex flex-col justify-center items-center group transition-all duration-200 relative focus:outline-none focus:ring-4 focus:ring-blue-100\">\n                            <span class=\"text-lg font-semibold text-slate-900 group-hover:text-blue-600 transition-colors\">4</span>\n                            <span class=\"absolute bottom-2 text-[10px] font-bold text-green-500 uppercase bg-green-50 px-2 py-0.5 rounded-full group-hover:bg-blue-50 group-hover:text-blue-600 transition-colors\">Available</span>\n                        </button>\n\n                        <!-- Weekend -->\n                        <div class=\"aspect-square rounded-xl bg-slate-50 border border-slate-100 flex flex-col justify-center items-center opacity-50\">\n                            <span class=\"text-lg text-slate-400\">5</span>\n                        </div>\n\n                        <!-- ... Add a few more row visual placeholders ... -->\n                        <div class=\"aspect-square rounded-xl bg-slate-50 border border-slate-100 flex flex-col justify-center items-center opacity-50\"><span class=\"text-lg text-slate-400\">6</span></div>\n                        \n                        <div class=\"aspect-square rounded-xl bg-red-50 border border-red-100 flex flex-col justify-center items-center opacity-70 cursor-not-allowed relative\">\n                            <span class=\"text-lg text-slate-600 line-through\">7</span>\n                        </div>\n\n                        <button class=\"aspect-square rounded-xl bg-white border-2 border-slate-100 hover:border-blue-600 hover:shadow-lg hover:shadow-blue-100 flex flex-col justify-center items-center group transition-all duration-200 relative\">\n                            <span class=\"text-lg font-semibold text-slate-900 group-hover:text-blue-600\">8</span>\n                            <span class=\"absolute bottom-2 text-[10px] font-bold text-green-500 uppercase bg-green-50 px-2 py-0.5 rounded-full group-hover:bg-blue-50 group-hover:text-blue-600\">Half-Day Only</span>\n                        </button>\n\n                         <button class=\"aspect-square rounded-xl bg-white border-2 border-slate-100 hover:border-blue-600 hover:shadow-lg hover:shadow-blue-100 flex flex-col justify-center items-center group transition-all duration-200 relative\">\n                            <span class=\"text-lg font-semibold text-slate-900 group-hover:text-blue-600\">9</span>\n                            <span class=\"absolute bottom-2 text-[10px] font-bold text-green-500 uppercase bg-green-50 px-2 py-0.5 rounded-full group-hover:bg-blue-50 group-hover:text-blue-600\">Available</span>\n                        </button>\n\n                        <button class=\"aspect-square rounded-xl bg-white border-2 border-slate-100 hover:border-blue-600 hover:shadow-lg hover:shadow-blue-100 flex flex-col justify-center items-center group transition-all duration-200 relative\">\n                            <span class=\"text-lg font-semibold text-slate-900 group-hover:text-blue-600\">10</span>\n                            <span class=\"absolute bottom-2 text-[10px] font-bold text-green-500 uppercase bg-green-50 px-2 py-0.5 rounded-full group-hover:bg-blue-50 group-hover:text-blue-600\">Available</span>\n                        </button>\n\n                        <div class=\"col-span-2 bg-slate-50 border border-slate-100 rounded-xl flex items-center justify-center text-sm text-slate-400\">\n                            Weekend\n                        </div>\n\n                    </div>\n                </div>\n                \n                <!-- CTA Area below calendar -->\n                <div class=\"bg-slate-50 border-t border-slate-100 p-8 flex flex-col sm:flex-row items-center justify-between gap-6\">\n                    <div class=\"flex items-center gap-4 text-sm text-slate-500\">\n                        <div class=\"flex items-center gap-2\"><span class=\"w-3 h-3 rounded-full bg-green-400\"></span> Available</div>\n                        <div class=\"flex items-center gap-2\"><span class=\"w-3 h-3 rounded-full bg-red-300\"></span> Booked</div>\n                    </div>\n                    <button class=\"px-8 py-3 bg-blue-600 text-white font-medium rounded-full shadow-lg shadow-blue-600/20 hover:bg-blue-700 hover:-translate-y-0.5 transition-all w-full sm:w-auto opacity-50 cursor-not-allowed\">\n                        Continue to Details\n                    </button>\n                </div>\n            </div>\n\n        </div>\n    </section>"
    },
    {
      "type": "custom_html",
      "html": "<footer class=\"bg-slate-900 text-slate-300 py-20 border-t border-slate-800\">\n        <div class=\"max-w-7xl mx-auto px-6 lg:px-8\">\n            <div class=\"grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-8\">\n                \n                <!-- Brand & Address (4 cols) -->\n                <div class=\"col-span-12 md:col-span-4 lg:col-span-4\">\n                    <div class=\"flex items-center gap-2 mb-6 text-white\">\n                        <div class=\"w-8 h-8 bg-blue-600 rounded flex items-center justify-center font-bold text-lg leading-none\">B</div>\n                        <span class=\"font-semibold text-xl tracking-tight\">Bruneman Mediations</span>\n                    </div>\n                    <p class=\"text-sm leading-relaxed mb-6 text-slate-400\">\n                        Campbell Centre, Tower II<br>\n                        8150 N. Central Expwy., 10th Floor<br>\n                        Dallas, Texas 75206\n                    </p>\n                    <a href=\"#\" class=\"inline-flex items-center text-sm font-medium text-blue-400 hover:text-blue-300 transition-colors\">\n                        Map &amp; Directions <svg class=\"w-4 h-4 ml-1\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14\"></path></svg>\n                    </a>\n                </div>\n\n                <!-- Contact (4 cols) -->\n                <div class=\"col-span-12 md:col-span-4 lg:col-span-4\">\n                    <h4 class=\"text-white font-semibold mb-6 uppercase tracking-wider text-sm\">Contact Us</h4>\n                    <ul class=\"space-y-4 text-sm\">\n                        <li class=\"flex items-start\">\n                            <span class=\"text-slate-500 w-16\">Phone:</span>\n                            <a href=\"tel:2147444440\" class=\"hover:text-white transition-colors\">214-744-4440</a>\n                        </li>\n                        <li class=\"flex items-start\">\n                            <span class=\"text-slate-500 w-16\">Fax:</span>\n                            <span>214-744-4441</span>\n                        </li>\n                    </ul>\n                </div>\n\n                <!-- Links & Payment (4 cols) -->\n                <div class=\"col-span-12 md:col-span-4 lg:col-span-4\">\n                    <h4 class=\"text-white font-semibold mb-6 uppercase tracking-wider text-sm\">Quick Links</h4>\n                    <ul class=\"space-y-3 text-sm mb-8\">\n                        <li><a href=\"#\" class=\"hover:text-white transition-colors\">Make a Payment</a></li>\n                        <li><a href=\"#about\" class=\"hover:text-white transition-colors\">About Steve</a></li>\n                        <li><a href=\"#calendar\" class=\"hover:text-white transition-colors\">Mediation Calendar</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition-colors\">Disclaimer &amp; Privacy Policy</a></li>\n                    </ul>\n                </div>\n\n            </div>\n            \n            <div class=\"mt-20 pt-8 border-t border-slate-800 text-xs text-slate-500 flex flex-col sm:flex-row justify-between items-center\">\n                <p>© 2026 Bruneman Mediations. All rights reserved.</p>\n                <!-- Design note as requested in prompt -->\n                <p class=\"mt-2 sm:mt-0 text-slate-600 italic\">Wireframe UI mockup. Typography: Inter (Sans-Serif).</p>\n            </div>\n        </div>\n    </footer>"
    }
  ]
}